# Yarn Zero-Install
# https://yarnpkg.com/getting-started/qa#which-files-should-be-gitignored
storybook-static
node_modules

.yarn/*
!.yarn/cache
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# testing
/coverage

# production
/dist

# misc
.DS_Store
*.local

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*


.github/rules